  "country_lookup_urls": [
    "https://ipapi.co/json/",
    "http://ip-api.com/json/?fields=status,country,countryCode,query",
    "https://ipwho.is/"
  ],
  "country_lookup_no_cache": true,
  "notify_on_public_ip_change": true,
  "tray_icon_tooltip": "Internet Checker",
  "tray_exit_label": "Exit"
